# Resend — transactional email (SEC-05)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL is OPTIONAL in Phase 2 — falls back to Resend sandbox onboarding@resend.dev
# Will be REQUIRED once the launch domain is verified (SEC-06, deferred to domain-cutover batch)
# RESEND_FROM_EMAIL=Input2PDF <hello@your-domain.com>

# Contact form — Sarmad's lead inbox (required in Phase 2, D-Q1 locked)
CONTACT_INBOX_EMAIL=your-gmail@gmail.com

# Upstash Redis — rate limiting (production). Optional in dev (falls back to in-memory Map).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# CSP Report-Only toggle — set to 1 during a browse session, remove to enforce.
# CSP_REPORT_ONLY=1
